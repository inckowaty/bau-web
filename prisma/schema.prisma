generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           Int    @id @default(autoincrement())
  username     String @unique
  passwordHash String

  @@map("admins")
}

model HomePage {
  id           Int    @id @default(autoincrement())
  lang         String
  heroTitle    String
  heroSubOne   String
  heroSubTwo   String
  heroSubThree String
  buttonLang   String
  heroBg       String

  @@unique([lang])
  @@map("home_pages")
}

model AboutPage {
  id             Int    @id @default(autoincrement())
  lang           String
  aboutTitle     String
  aboutIntro     String
  aboutPointsRaw String
  aboutCtaText   String

  @@unique([lang])
  @@map("about_pages")
}

model Service {
  id          Int    @id @default(autoincrement())
  lang        String
  title       String
  iconUrl     String
  excerpt     String
  featuresRaw String
  sortOrder   Int    @default(0)

  @@map("services")
}

model GalleryImage {
  id        Int    @id @default(autoincrement())
  lang      String
  url       String
  width     Int?
  height    Int?
  sortOrder Int    @default(0)

  @@map("gallery_images")
}

model NavItem {
  id        Int    @id @default(autoincrement())
  lang      String
  title     String
  path      String
  sortOrder Int    @default(0)

  @@map("nav_items")
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  lang      String   @default("de")
  createdAt DateTime @default(now())

  @@map("contact_messages")
}
